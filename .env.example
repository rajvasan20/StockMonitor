# Anthropic API Key — required for AI narrative generation in thesis reports
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# X/Twitter API — required for posting thesis threads
# Get credentials from: https://developer.x.com/en/portal/dashboard
# App must have Read+Write permissions
X_API_KEY=your-api-key
X_API_SECRET=your-api-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret

# Email alerts (for universe monitor bargain alerts)
STOCK_MONITOR_EMAIL_FROM=your-email@gmail.com
STOCK_MONITOR_EMAIL_PWD=your-app-password
